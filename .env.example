OPENAI_API_KEY=sk-your-openai-key

# Optional OpenRouter fallback (used when OpenAI is rate-limited/quota-limited)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Qdrant - use localhost for local Docker, or Qdrant Cloud URL
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=legacylens

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# LLM
LLM_MODEL=gpt-4o

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval
TOP_K=5

# Codebase path (local Docker or Railway volume)
CODEBASE_PATH=./codebase/gnucobol
